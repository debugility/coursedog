# PUSHING THIS BECAUSE IT IS A TEST PROJECT.

# ============================================
# Environment Configuration
# ============================================
BASE_URL=https://qa-practice.razvanvancea.ro
DEFAULT_PASSWORD=admin123

# ============================================
# Playwright Configuration
# ============================================
BROWSER_MODE=headless
ACTION_TIMEOUT=40000
NAVIGATION_TIMEOUT=40000
EXPECT_TIMEOUT=10000
NETWORK_IDLE_TIMEOUT=40000

# ============================================
# Test Execution Configuration
# ============================================
TEST_RETRIES=1
WORKERS=1
PARALLEL_EXECUTION=true
TEST_TIMEOUT=420000

# ============================================
# Trace and Reporting Configuration
# ============================================
TRACE_MODE=on-first-retry
SCREENSHOT_MODE=only-on-failure
VIDEO_MODE=retain-on-failure

# ============================================
# Viewport Configuration
# ============================================
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# ============================================
# CI/CD Configuration
# ============================================
CI=false

# ============================================
# Debug and Development Configuration
# ============================================
SLOW_MO=0
DEBUG=false
CONSOLE_LOG=false

# ============================================
# Reporting and Artifacts
# ============================================
REPORTER=allure
ARTIFACT_RETENTION_DAYS=30